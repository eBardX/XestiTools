ce"},{"text":" elements produced by the ","type":"text"},{"code":"transform","type":"codeVoice"},{"type":"text","text":" closure. The sequence"},{"text":" ","type":"text"},{"type":"text","text":"ends either when the base sequence ends or when "},{"code":"transform","type":"codeVoice"},{"text":" throws an","type":"text"},{"type":"text","text":" "},{"text":"error.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"compactMap(_:)","type":"codeVoice"},{"type":"text","text":" method to transform every element received from"},{"type":"text","text":" "},{"type":"text","text":"a base asynchronous sequence, while also discarding any "},{"code":"nil","type":"codeVoice"},{"text":" results","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from the closure. Typically, you use this to transform from one type of"},{"text":" ","type":"text"},{"type":"text","text":"element to another."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"code":"1","type":"codeVoice"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"text":". The closure provided to the ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" "},{"text":"method takes each ","type":"text"},{"code":"Int","type":"codeVoice"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"text":" ","type":"text"},{"code":"romanNumeralDict","type":"codeVoice"},{"text":" dictionary. Since there is no key for ","type":"text"},{"type":"codeVoice","code":"4"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" in this case, which ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" omits from the"},{"type":"text","text":" "},{"type":"text","text":"transformed asynchronous sequence. When the value is "},{"code":"5","type":"codeVoice"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"throws ","type":"text"},{"type":"codeVoice","code":"MyError"},{"type":"text","text":", terminating the sequence."}],"type":"paragraph"},{"code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","\/\/ Prints \"I II III Error: MyError() \""],"syntax":null,"type":"codeListing"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/XestiTools\/documentation\/XestiTools\/AsyncJSONValueSequence\/compactMap(_:)-11mo0","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/XestiTools\/documentation\/XestiTools","doc:\/\/XestiTools\/documentation\/XestiTools\/AsyncJSONValueSequence"]]},"abstract":[{"text":"Creates an asynchronous sequence that maps an error-throwing closure over","type":"text"},{"text":" ","type":"text"},{"text":"the base sequence’s elements, omitting results that don’t return a value.","type":"text"}],"references":{"doc://XestiTools/documentation/XestiTools/AsyncJSONValueSequence":{"navigatorTitle":[{"kind":"identifier","text":"AsyncJSONValueSequence"}],"role":"symbol","url":"\/documentation\/xestitools\/asyncjsonvaluesequence","abstract":[{"text":"An asynchronous sequence of values decoded from t