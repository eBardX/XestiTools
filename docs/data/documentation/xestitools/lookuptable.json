olatableValue"},{"text":", ","kind":"text"},{"text":"Interp","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:10XestiTools12InterpolatorP","text":"Interpolator","kind":"typeIdentifier","identifier":"doc:\/\/XestiTools\/documentation\/XestiTools\/Interpolator"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Unlike a dictionary, a ","type":"text"},{"code":"LookupTable","type":"codeVoice"},{"text":" instance does not require an exact key","type":"text"},{"text":" ","type":"text"},{"text":"match. Each entry is a (key, value) anchor, and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/XestiTools\/documentation\/XestiTools\/LookupTable\/subscript(_:)","type":"reference"},{"text":" ","type":"text"},{"text":"interpolates between the two entries that bracket a queried key. Every key","type":"text"},{"text":" ","type":"text"},{"text":"within range of the lookup table therefore yields a meaningful value, not","type":"text"},{"text":" ","type":"text"},{"text":"just the keys that were explicitly inserted.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Given a key, the lookup table:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Finds the two entries that bracket the key.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Computes the input fraction via","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/XestiTools\/documentation\/XestiTools\/InterpolatableKey\/fraction(from:through:)","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Maps the input fraction through ","type":"text"},{"identifier":"doc:\/\/XestiTools\/documentation\/XestiTools\/Interpolator\/checkedInterpolate(_:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"to